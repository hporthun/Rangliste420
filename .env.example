# ── Datenbank ──────────────────────────────────────────────────────────────────

# Lokal (Neon Dev-Branch oder lokale Postgres):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Neon gibt zwei URLs aus: "Pooled connection" (DATABASE_URL) und
# "Direct connection" (DATABASE_URL_UNPOOLED). Beide eintragen.

# ── Auth (NextAuth v5) ─────────────────────────────────────────────────────────

# Zufallsschlüssel generieren: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"

# Nur in Produktion nötig (Vercel setzt VERCEL_URL automatisch, aber explizit setzen):
# AUTH_URL="https://deine-domain.vercel.app"

# ── Backup ────────────────────────────────────────────────────────────────────

# Backup-Verzeichnis (lokal: leer lassen = ./data/backups; Vercel: /tmp)
# BACKUP_DIR="/tmp"
