# ── Datenbank ──────────────────────────────────────────────────────────────────
#
# Lokal (Default): SQLite — keine DATABASE_URL nötig, Prisma legt prisma/dev.db an.
# Optional explizit: DATABASE_URL="file:./dev.db"
#
# Auf Vercel/Neon (PostgreSQL):
#   DATABASE_URL          — Pooled-Connection (PgBouncer), z. B. "...neon-pooler..."
#   DATABASE_URL_UNPOOLED — Direkt-Connection, von Prisma Migrate genutzt
#
# DATABASE_URL="postgresql://user:password@ep-xyz-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xyz.eu-central-1.aws.neon.tech/dbname?sslmode=require"

# ── Auth (NextAuth v5) ─────────────────────────────────────────────────────────

# Zufallsschlüssel generieren: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"

# Auf Vercel: AUTH_URL setzen oder Vercel-Auto-Detection nutzen.
# Lokal nicht nötig.
# AUTH_URL="https://deine-domain.vercel.app"

# ── OAuth-Anmeldung (optional, Issue #25) ─────────────────────────────────────
#
# Jeder Provider wird AKTIV, sobald seine *_CLIENT_ID + *_CLIENT_SECRET gesetzt
# sind. Sicherheit: OAuth-Login funktioniert nur, wenn die vom Provider
# gelieferte E-Mail einer existierenden User.email in der Datenbank entspricht
# (kein Self-Sign-up). Der Callback-URL-Pfad ist immer
# /api/auth/callback/<provider> — bei Vercel im Dashboard der Auth-Provider
# eintragen.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# Microsoft Entra ID (Azure AD) → App registrations → New registration
# MICROSOFT_ENTRA_ID_CLIENT_ID=""
# MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
# MICROSOFT_ENTRA_ID_TENANT_ID="common"   # "common" = beliebiges Tenant
#
# Apple → Apple Developer → Sign in with Apple → Service ID + Secret-JWT
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""
#
# Meta (Facebook Login) → Meta for Developers → My Apps → App settings
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# ── Backup ────────────────────────────────────────────────────────────────────

# Lokal: leer lassen, Backups landen in ./data/backups
# BACKUP_DIR="/tmp/backups"
#
# Auf Vercel (Phase 1): Backups sind temporär deaktiviert. Phase 2 nutzt
# Vercel Blob als Storage; keine BACKUP_DIR-Variable nötig.

# ── E-Mail-Versand (SMTP, optional aber für Passwort-Reset nötig) ────────────
#
# Issue #29: Passwort-Reset per E-Mail. Ohne SMTP-Konfiguration wird kein
# Reset-Link versendet — der generierte Link erscheint dann nur als Warnung
# in den Server-Logs.
#
# Beispiel Strato:
# SMTP_HOST="smtp.strato.de"
# SMTP_PORT="587"             # 587 = STARTTLS, 465 = SSL/TLS
# SMTP_USER="absender@meine-domain.de"
# SMTP_PASS="secret"
# MAIL_FROM="420er Rangliste <noreply@meine-domain.de>"

# ── Zeitzone ──────────────────────────────────────────────────────────────────
# Wichtig auf Vercel — sonst läuft alles in UTC, was die Backup-Zeiten und
# Stichtage verschiebt.
TZ="Europe/Berlin"
