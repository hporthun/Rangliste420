# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# data
/data

# claude
.claude/settings.local.json
.claude/launch.json

# sqlite dev db
*.db
*.db-shm
*.db-wal
*.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# scratch / paste-test files in repo root that are not meant to be tracked
# (z.B. wenn man M2S-Pastes lokal in eine .txt zur Diagnose ablegt)
/Sailors.txt
/*.scratch.*
/scratch-*
