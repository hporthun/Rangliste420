# next-auth@5.0.0-beta.31 deklariert nodemailer@^7 als peerOptional, wir
# nutzen aber bewusst nodemailer 8 (Issue #58, SMTP-Injection-Patch).
# next-auth bindet nodemailer nur fuer den nicht aktivierten Email-Provider,
# daher funktional kein Konflikt. legacy-peer-deps=true sorgt dafuer, dass
# `npm install` und `npm ci` auf Vercel diesen Override gleich behandeln,
# sonst kippt der Production-Build (Lockfile-Drift gegen npm-ci-Strict).
legacy-peer-deps=true
