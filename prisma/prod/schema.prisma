// Produktions-Schema für Vercel + Neon PostgreSQL.
// AUTO-GENERIERT aus prisma/schema.prisma — NICHT manuell editieren.
// Re-generieren mit: npm run db:sync-prod
//
// Lokal wird prisma/schema.prisma (SQLite) verwendet.
// Vercel-Build:  prisma migrate deploy --schema=prisma/prod/schema.prisma
//             && prisma generate     --schema=prisma/prod/schema.prisma
//             && next build

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Pooled connection (PgBouncer) — used by the application at runtime.
  // For Neon the pooled URL ends with `-pooler.<region>.neon.tech`.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection — required by Prisma Migrate.
  // Falls back to DATABASE_URL when DATABASE_URL_UNPOOLED is unset.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Sailor {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  birthYear        Int?
  // "M" | "F" | null — null excludes from gender-filtered rankings
  gender           String?
  // ISO-3166-1 alpha-3, default GER
  nationality      String    @default("GER")
  club             String?
  sailingLicenseId String?
  // JSON-serialized string array of alternative names used for fuzzy matching
  alternativeNames String    @default("[]")
  // Mitglied der 420er-Klassenvereinigung — Pflicht für JWM/JEM-Quali
  member420        Boolean   @default(true)

  helmEntries TeamEntry[] @relation("HelmSailor")
  crewEntries TeamEntry[] @relation("CrewSailor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Regatta ───────────────────────────────────────────────────────────────────
model Regatta {
  id                   String    @id @default(cuid())
  name                 String
  location             String?
  // ISO-3166-1 alpha-3; non-GER = foreign regatta
  country              String    @default("GER")
  startDate            DateTime
  endDate              DateTime
  numDays              Int       @default(1)
  plannedRaces         Int?
  completedRaces       Int
  // Anzahl der gestarteten Boote insgesamt — inkl. ausländische Crews.
  // Wird beim Import aus der Quelle übernommen, kann manuell nachträglich
  // korrigiert werden. Wenn null, fällt die Berechnung auf
  // results.length zurück (für ältere Datensätze ohne den Wert).
  // Wichtig für die DSV-Formel: s = totalStarters ?? results.length
  totalStarters        Int?
  multiDayAnnouncement Boolean   @default(false)
  // 0.80–2.60 per DSV-RO
  ranglistenFaktor     Decimal
  // "LOW_POINT" | "BONUS_POINT"
  scoringSystem        String    @default("LOW_POINT")
  isRanglistenRegatta  Boolean   @default(false)
  // "MANAGE2SAIL_PASTE" | "MANAGE2SAIL_PDF" | "SAILWAVE" | "GENERIC_CSV" | "MANUAL"
  sourceType           String    @default("MANAGE2SAIL_PASTE")
  sourceUrl            String?
  sourceFile           String?
  importedAt           DateTime?
  notes                String?

  teamEntries     TeamEntry[]
  results         Result[]
  rankingRegattas RankingRegatta[]
  importSessions  ImportSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── TeamEntry ─────────────────────────────────────────────────────────────────
// One row per helm per regatta. Crew can differ across regattas (Schottenwechsel).
model TeamEntry {
  id               String   @id @default(cuid())
  regattaId        String
  helmId           String
  // crewId may be null when imported from PDF (only helm known)
  crewId           String?
  sailNumber       String?
  crewSwapApproved Boolean  @default(false)
  crewSwapNote     String?

  regatta Regatta  @relation(fields: [regattaId], references: [id], onDelete: Cascade)
  helm    Sailor   @relation("HelmSailor", fields: [helmId], references: [id])
  crew    Sailor?  @relation("CrewSailor", fields: [crewId], references: [id])
  result  Result?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each helm appears at most once per regatta
  @@unique([regattaId, helmId])
  @@index([helmId])
  @@index([crewId])
}

// ── Result ────────────────────────────────────────────────────────────────────
model Result {
  id          String   @id @default(cuid())
  regattaId   String
  teamEntryId String   @unique
  finalRank   Int?
  finalPoints Decimal?
  // JSON-serialized: Array<{ race: number; points: number; code?: string; isDiscard?: boolean }>
  racePoints  String   @default("[]")
  // true if boat reached start area but never crossed finish (DNS/BFD/OCS)
  // such boats get R_A = 0 but count in s and m-fold in value list
  inStartArea Boolean  @default(false)
  // true wenn finalRank vom Admin manuell vergeben wurde — schuetzt den Rang
  // gegen Auto-Reranking durch rerankRegatta beim Editieren anderer Eintraege
  // derselben Regatta. Wird ausschliesslich von der manuellen Bearbeitungs-UI
  // gesetzt; der Import setzt es nie.
  isRankManual Boolean  @default(false)

  regatta   Regatta   @relation(fields: [regattaId], references: [id], onDelete: Cascade)
  teamEntry TeamEntry @relation(fields: [teamEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regattaId, teamEntryId])
  @@index([regattaId])
}

// ── Ranking ───────────────────────────────────────────────────────────────────
// Stored only for: Jahresrangliste (snapshot), JWM_QUALI, JEM_QUALI.
// Aktuelle Rangliste and IDJM-Quali are computed on-demand, not stored.
model Ranking {
  id             String    @id @default(cuid())
  name           String
  // "JAHRESRANGLISTE" | "IDJM" | "JWM_QUALI" | "JEM_QUALI"
  // ("AKTUELLE" is computed live and never stored.)
  type           String
  // flexible season window (e.g. 2025-01-01 to 2025-11-30)
  seasonStart    DateTime
  seasonEnd      DateTime
  // "U15" | "U16" | "U17" | "U19" | "OPEN"
  ageCategory    String
  // "OPEN" | "MEN" | "MIX" | "GIRLS"
  genderCategory String
  // JSON-serialized: DsvScoringRule | JwmJemQualiScoringRule
  scoringRule    String
  isPublic       Boolean   @default(false)
  publishedAt    DateTime?
  // Display order in the public listing (lower = higher up); ties broken by publishedAt desc
  sortOrder      Int       @default(0)
  // "HELM" | "CREW" — scoring unit (Steuermann or Vorschoter)
  scoringUnit    String    @default("HELM")

  rankingRegattas RankingRegatta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── RankingRegatta ────────────────────────────────────────────────────────────
// Associates regattas to a ranking. weight only used for JWM/JEM-Quali.
model RankingRegatta {
  rankingId String
  regattaId String
  weight    Float?

  ranking Ranking @relation(fields: [rankingId], references: [id], onDelete: Cascade)
  regatta Regatta @relation(fields: [regattaId], references: [id])

  @@id([rankingId, regattaId])
}

// ── ImportSession ─────────────────────────────────────────────────────────────
model ImportSession {
  id             String   @id @default(cuid())
  regattaId      String
  createdBy      String
  // "MANAGE2SAIL_PASTE" | "MANAGE2SAIL_PDF" | ...
  parserType     String
  sourceFile     String?
  // JSON-serialized record of fuzzy-match decisions {accepted: [], rejected: [], created: []}
  matchDecisions String   @default("{}")

  regatta Regatta @relation(fields: [regattaId], references: [id])

  createdAt DateTime @default(now())

  @@index([regattaId])
}

// ── User ──────────────────────────────────────────────────────────────────────
model User {
  id           String  @id @default(cuid())
  // username is the primary login identifier (set at seed / account settings)
  username     String? @unique
  // email is optional; used for display/contact, not required for login
  email        String? @unique
  passwordHash String?
  // "ADMIN" | "EDITOR" — Editor darf Inhalt pflegen (Segler, Regatten,
  // Ranglisten), aber nicht /admin/wartung oder /admin/benutzer.
  // Default beim Anlegen über die Benutzerverwaltung ist "EDITOR" — der Seed
  // legt weiterhin einen ADMIN an.
  role         String  @default("EDITOR")

  // ── Manuelle Sperrung (Issue #49) ──────────────────────────────────────────
  // Setzt der Admin in der Benutzerverwaltung. Solange disabledAt != null,
  // schlägt jeder Login-Versuch fehl und vorhandene Sessions werden bei der
  // nächsten Auth-Prüfung ungültig (siehe tokenVersion).
  disabledAt   DateTime?
  // User-ID des Admins, der gesperrt hat (für Audit/Anzeige).
  disabledBy   String?

  // ── Session-Invalidierung (Issue #49) ──────────────────────────────────────
  // Wird in jeden ausgegebenen JWT eingebettet. Bei "Rauswerfen" oder
  // Sperrung erhöht sich der Wert; vorhandene JWTs werden beim nächsten
  // Request via lib/auth-guard.ts verworfen.
  tokenVersion Int       @default(0)

  // ── TOTP 2-Factor Auth ─────────────────────────────────────────────────────
  totpSecret      String?
  totpEnabled     Boolean @default(false)
  // JSON array of bcrypt-hashed one-time backup codes
  totpBackupCodes String  @default("[]")

  // ── Brute-force protection ─────────────────────────────────────────────────
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // ── Password reset ─────────────────────────────────────────────────────────
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // ── Changelog read marker ─────────────────────────────────────────────────
  // Latest changelog version the user has acknowledged. null = never seen any
  // popup (new user); the popup only fires when there are entries with a
  // version > this value.
  lastReadChangelogVersion String?

  webAuthnCredentials WebAuthnCredential[]
  pushSubscriptions   PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── WebAuthnCredential ────────────────────────────────────────────────────────
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  // base64url-encoded credential ID from the authenticator
  credentialId String    @unique
  // base64url-encoded COSE public key
  publicKey    String
  counter      BigInt    @default(0)
  // "singleDevice" | "multiDevice"
  deviceType   String    @default("singleDevice")
  backedUp     Boolean   @default(false)
  // JSON array of AuthenticatorTransport strings
  transports   String    @default("[]")
  // user-given name, e.g. "iPhone", "YubiKey"
  name         String    @default("Passkey")
  lastUsed     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ── WebAuthnChallenge ─────────────────────────────────────────────────────────
// Short-lived challenges for WebAuthn register/authenticate flows.
// Also used as single-use passkey session tokens after successful authentication.
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  // "register" | "authenticate" | "passkey-session"
  type      String
  challenge String   @unique
  userId    String?
  expiresAt DateTime

  createdAt DateTime @default(now())
}

// ── MailConfig ────────────────────────────────────────────────────────────────
// Singleton: at most one row (id = 1). Persists SMTP credentials configured
// via the admin UI (Issue #32). When enabled, this overrides any SMTP_*
// env vars; when disabled (or absent), the mailer falls back to env vars.
// password is stored in plain text — same trust model as BackupSchedule's
// encryptionPassword: the DB is admin-only.
model MailConfig {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  host      String   @default("")
  port      Int      @default(587)
  username  String   @default("")
  password  String   @default("")
  fromAddr  String   @default("")
  updatedAt DateTime @updatedAt
}

// ── BackupSchedule ────────────────────────────────────────────────────────────
// Singleton: at most one row (id = 1). Persists the user-configured backup
// schedule across restarts. On Vercel/serverless this is the only place the
// schedule survives — the previous file-based config (data/backups/_schedule.json)
// did not survive between function invocations.
model BackupSchedule {
  id                 Int      @id @default(1)
  enabled            Boolean  @default(false)
  hour               Int      @default(2)
  minute             Int      @default(0)
  // JSON-serialized number array, e.g. "[1]" = Mondays only, "[]" = every day
  daysOfWeek         String   @default("[1]")
  maxKeep            Int      @default(30)
  encryptionPassword String   @default("")
  updatedAt          DateTime @updatedAt
}

// ── PushSubscription ──────────────────────────────────────────────────────────
// Anonymous Web-Push subscription per browser (Issue #36). The subscription
// endpoint uniquely identifies the device — no User foreign key, since public
// visitors can subscribe without an account. Stale subscriptions (browser
// uninstalled, key rotated) are removed when the push service returns 410.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  // Free-form, used to help debugging which device is subscribed
  userAgent String?
  // null = anonyme Public-Subscription. Gesetzt = Browser einer eingeloggten
  // Sitzung (Admin/Editor). Wird verwendet, um Update-Notifications nur an
  // angemeldete Subscriptions zu schicken (Public-Visitors brauchen keine
  // App-Versions-Pushes; sie abonnieren primaer Ranking-Updates).
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([userId])
}

// ── PushBroadcastState ────────────────────────────────────────────────────────
// Singleton: at most one row (id = 1). Stores the latest APP_VERSION that has
// already been pushed out as "neue Version verfügbar" — so the boot-time
// check in instrumentation.ts can broadcast exactly once per release, even
// across multiple serverless instances.
model PushBroadcastState {
  id                Int      @id @default(1)
  lastPushedVersion String?
  updatedAt         DateTime @updatedAt
}

// ── AuditLog ──────────────────────────────────────────────────────────────────
// Immutable record of security-relevant events.
model AuditLog {
  id        String   @id @default(cuid())
  // Nullable: some events happen before a session is established (login failures)
  userId    String?
  // e.g. "LOGIN_SUCCESS" | "LOGIN_FAILED" | "PASSWORD_CHANGE" | "DATA_DELETE_ALL"
  action    String
  // Free-text detail, e.g. username used, number of deleted records
  detail    String?
  // IP address of the request
  ip        String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// ── RateLimitEntry ────────────────────────────────────────────────────────────
// Sliding-Window-Counter fuer IP- (oder User-) basiertes Rate-Limiting,
// Issue #59. Persistent in der DB, weil Vercel-Serverless-Instanzen ihren
// In-Memory-State zwischen Cold-Starts verlieren. Cleanup laeuft lazy
// beim Lesen — Eintraege ohne aktuelle Timestamps werden geloescht.
//
// `key` ist ein zusammengesetzter Schluessel, z.B. "login:1.2.3.4".
// `timestamps` ist ein JSON-Array von epoch-ms-Werten (String, weil sowohl
// SQLite als auch Postgres-Schema kompatibel bleiben sollen).
model RateLimitEntry {
  key        String   @id
  timestamps String
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
}
